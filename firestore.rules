rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // 2. Validation Blueprint
    function isValidTransformation(data) {
      return data.userId == request.auth.uid &&
             data.originalImageUrl is string && data.originalImageUrl.size() < 2000 &&
             data.transformedImageUrl is string && data.transformedImageUrl.size() < 2000 &&
             data.type in ['age_progression', 'actor_swap', 'background_change', 'vintage', 'anime'] &&
             data.createdAt == request.time;
    }

    // Match transformations
    match /users/{userId}/transformations/{transformationId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isValidId(transformationId) && 
                      isValidTransformation(incoming()) &&
                      incoming().keys().hasAll(['userId', 'originalImageUrl', 'transformedImageUrl', 'type', 'createdAt']) &&
                      incoming().keys().size() >= 5;
      
      allow update: if false; // Transformations should be immutable
      allow delete: if isOwner(userId);
    }
  }
}
